# Convex deployment (set by Convex CLI after running `npx convex dev`)
CONVEX_DEPLOYMENT=

# GitHub OAuth application credentials
# Create one at: https://github.com/settings/applications/new
# Authorization callback URL: https://your-deployment-url/auth/callback
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Vercel environment variable — automatically set in Vercel deployments
VERCEL_URL=

# Claude API (for Chat Designer AI)
CLAUDE_API_KEY=
